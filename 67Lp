        end
    end
end)










-- Esp v1


local s_p = "Si".."ze"
local h_p = "He".."ad"
local t_p = "Tor".."so"
local tr_p = "Trans".."parency"
local d_p = "Z".."Data".."99" 

game:GetService("RunService").Heartbeat:Connect(function()
    if not _G.Z_Hitbox_Active and not _G.Z_Force_Reset then return end
    
    local lp = game.Players.LocalPlayer
    local val_size = _G.Z_Hitbox_Size or 20
    local v_size = Vector3.new(val_size, val_size, val_size)

    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= lp and p.Character then
            local char = p.Character
            
            local is_team = _G.Z_Team_Check and lp.Team and p.Team == lp.Team
            if not _G.Z_Hitbox_Active or _G.Z_Force_Reset or is_team then
                for _, part in pairs(char:GetChildren()) do
                    local backup = part:FindFirstChild(d_p)
                    if backup then
                        part[s_p] = backup.Value
                        part[tr_p] = 0
                        part.CanCollide = true
                    end
                end
                if is_team then continue end
            end

            if not _G.Z_Hitbox_Active then continue end

            local targets = {}
            -- FIX AQUÍ: Forzamos la búsqueda de la cabeza
            if _G.Z_Hitbox_Mode == "Head" then
                local head = char:FindFirstChild(h_p) or char:FindFirstChild("FakeHead")
                if head then table.insert(targets, head) end
            elseif _G.Z_Hitbox_Mode == "Torso" then
                local torso = char:FindFirstChild(t_p) or char:FindFirstChild("Upper"..t_p) or char:FindFirstChild("Lower"..t_p)
                if torso then table.insert(targets, torso) end
            elseif _G.Z_Hitbox_Mode == "Huesos" then
                local bones = {"Left Arm", "Right Arm", "Left Leg", "Right Leg", "LeftUpperArm", "RightUpperArm", "LeftUpperLeg", "RightUpperLeg"}
                for _, b in pairs(bones) do 
                    local bp = char:FindFirstChild(b)
                    if bp then table.insert(targets, bp) end
                end
            end

            for _, obj in pairs(targets) do
                if obj and obj:IsA("BasePart") then -- Verificamos que sea una parte
                    if obj[s_p] ~= v_size then
                        if not obj:FindFirstChild(d_p) then
                            local s = Instance.new("Vector3Value", obj)
                            s.Name = d_p
                            s.Value = obj[s_p]
                        end
                        
                        obj[s_p] = v_size
                        obj[tr_p] = 0.6
                        obj.Color = Color3.fromRGB(255, 0, 0)
                        obj.Material = Enum.Material.Neon
                        obj.CanCollide = false
                        obj.Massless = true
                        
                        -- Bypass extra para cabezas con Mesh
                        local m = obj:FindFirstChildOfClass("SpecialMesh")
                        if m then m.Scale = Vector3.new(1,1,1) end 
                    end
                end
            end
        end
    end
    _G.Z_Force_Reset = false 
end)

